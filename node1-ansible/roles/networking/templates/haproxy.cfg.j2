global
    log /dev/log local0
    user haproxy
    group haproxy
    daemon

defaults
    log global
    mode http
    timeout connect 5000
    timeout client 50000
    timeout server 50000

frontend web_front
    bind *:{{ haproxy_frontend_port }}
    default_backend web_servers

backend web_servers
    balance roundrobin
{% for c in web_containers %}
    server {{ c.name }} 127.0.0.1:{{ c.host_port }} check
{% endfor %}
